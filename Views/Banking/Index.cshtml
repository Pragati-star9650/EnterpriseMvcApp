@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Banking";
}

<div class="admin-page">

    <!-- LEFT TREE MENU -->
    <div class="admin-sidebar">
        <h5 class="admin-heading">Banking</h5>

        <ul class="admin-tree">

            <li>
                <span class="tree-parent" onclick="toggleMenu(this)">
                    ▸ Payments
                </span>
                <ul class="tree-child">
                    <li><a asp-action="IncomingPayments">Incoming Payments</a></li>
                    <li><a asp-action="OutgoingPayments">Outgoing Payments</a></li>
                </ul>
            </li>

        </ul>
    </div>

    <!-- RIGHT CONTENT AREA -->
    <div class="admin-content">
        <h2>Banking</h2>
        <p>Select a banking function from the left panel.</p>
    </div>

</div>

<script>
    function toggleMenu(element) {
        const child = element.nextElementSibling;

        if (child.style.display === "block") {
            child.style.display = "none";
            element.innerHTML = element.innerHTML.replace("▾", "▸");
        } else {
            child.style.display = "block";
            element.innerHTML = element.innerHTML.replace("▸", "▾");
        }
    }
</script>
