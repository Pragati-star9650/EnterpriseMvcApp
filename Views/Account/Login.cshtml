@model EnterpriseMvcApp.Models.LoginViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Enterprise Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="bg-light">

    <div class="container vh-100 d-flex justify-content-center align-items-center">
        <div class="card shadow" style="width: 360px;">
            <div class="card-header text-center bg-primary text-white">
                <h5>Enterprise System Login</h5>
            </div>

            <div class="card-body">

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">
                        @ViewBag.Error
                    </div>
                }

                <!-- 🔴 FORM START -->
                <form asp-action="Login" method="post">

                    <!-- SERVER -->
                    <div class="mb-3">
                        <label class="form-label">Server Name</label>
                        <select id="serverSelect"
                                name="ServerName"
                                class="form-select">
                            <option value="">-- Select Server --</option>
                        </select>
                    </div>

                    <!-- DATABASE -->
                    <div class="mb-3">
                        <label class="form-label">Database Name</label>
                        <select id="databaseSelect"
                                name="DatabaseName"
                                class="form-select">
                            <option value="">-- Select Database --</option>
                        </select>
                    </div>

                    <!-- USERNAME -->
                    <div class="mb-3">
                        <label asp-for="UserName"></label>
                        <input asp-for="UserName"
                               class="form-control" />
                    </div>

                    <!-- PASSWORD -->
                    <div class="mb-3">
                        <label asp-for="Password"></label>
                        <input asp-for="Password"
                               type="password"
                               class="form-control" />
                    </div>

                    <button type="submit"
                            class="btn btn-primary w-100">
                        Login
                    </button>

                </form>
                <!-- 🔴 FORM END -->

            </div>
        </div>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            // 🔵 SERVER API CALL
            fetch('http://192.168.7.2:82/api/ItemMaster')
                .then(res => res.json())
                .then(data => {

                    const serverSelect =
                        document.getElementById('serverSelect');

                    serverSelect.innerHTML =
                        '<option value="">-- Select Server --</option>';

                    data.forEach(item => {
                        serverSelect.innerHTML +=
                            `<option value="${item.serverName}">
                                ${item.serverName}
                            </option>`;
                    });

                })
                .catch(error => {
                    alert("Server API not reachable");
                    console.log(error);
                });


            // 🔵 DATABASE API CALL
            document.getElementById('serverSelect')
                .addEventListener('change', function () {

                const server = this.value;

                if (!server) return;

                fetch('http://192.168.7.2:82/api/ItemMaster')
                    .then(res => res.json())
                    .then(data => {

                        const dbSelect =
                            document.getElementById('databaseSelect');

                        dbSelect.innerHTML =
                            '<option value="">-- Select Database --</option>';

                        data.forEach(item => {
                            dbSelect.innerHTML +=
                                `<option value="${item.databaseName}">
                                    ${item.databaseName}
                                </option>`;
                        });

                    })
                    .catch(error => {
                        alert("Database API not reachable");
                        console.log(error);
                    });

            });

        });
    </script>

</body>
</html>
