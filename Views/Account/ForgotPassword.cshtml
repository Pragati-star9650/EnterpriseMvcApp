@{
    Layout = null;
    ViewData["Title"] = "Forgot Password";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Enterprise</title>
    <link rel="stylesheet" href="~/css/sap-login.css" asp-append-version="true" />
</head>
<body class="sap-login-page">
    <div class="sap-login-wrapper">
        <div class="sap-login-card">
            <div class="sap-login-header">
                <h1>Forgot / Reset Password</h1>
            </div>
            <div class="sap-login-body">
                <p class="sap-dashboard-text" style="margin-bottom: 1rem;">Contact your administrator to reset your password.</p>
                <div class="sap-login-links">
                    <a asp-action="Login">&larr; Back to Login</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
