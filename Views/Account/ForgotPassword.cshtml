@{
    Layout = null;
    ViewData["Title"] = "Forgot Password";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Enterprise</title>
    <link rel="stylesheet" href="~/css/sap-login.css" asp-append-version="true" />
</head>

<body class="sap-login-page theme-sap">

    <div class="login-container">

        <!-- LEFT SIDE IMAGE -->
        <div class="login-left"></div>

        <!-- RIGHT SIDE CARD -->
        <div class="login-right">

            <div class="sap-login-card">

                <div class="sap-login-header">
                    <img src="~/images/logo.png" class="login-logo" />
                    <h1>AYUSHMAN SOLUTIONS</h1>
                    <p class="login-subtitle">Forgot / Reset Password</p>
                </div>

                <div class="sap-login-body">

                    <p style="text-align:center; margin-bottom:20px;">
                        Contact your administrator to reset your password.
                    </p>

                    <div class="sap-login-links">
                        <a asp-action="Login">&larr; Back to Login</a>
                    </div>

                </div>

            </div>

        </div>

    </div>

</body>
</html>