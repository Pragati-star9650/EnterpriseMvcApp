@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Administration";
}

<div class="admin-page">

    <!-- LEFT TREE MENU -->
    <div class="admin-sidebar">
        <h5 class="admin-heading">Administration</h5>

        <ul class="admin-tree">

            <li>
                <span class="tree-title">Choose Company</span>
            </li>

            <li>
                <span class="tree-parent" onclick="toggleMenu(this)">
                    ▸ System Initialization
                </span>
                <ul class="tree-child">
                    <li><a asp-action="CompanySetup">Company Details</a></li>
                    <li><a asp-action="GeneralSettings">General Settings</a></li>
                    <li><a asp-action="DocumentNumbering">Document Numbering</a></li>
                </ul>
            </li>

            <li>
                <span class="tree-parent" onclick="toggleMenu(this)">
                    ▸ Setup
                </span>
                <ul class="tree-child">
                    <li><a asp-action="Users">Users</a></li>
                    <li><a asp-action="Authorizations">Authorizations</a></li>
                </ul>
            </li>

            <li>
                <span class="tree-title">Utilities</span>
            </li>

            <li>
                <span class="tree-title">Add-Ons</span>
            </li>

        </ul>
    </div>

    <!-- RIGHT CONTENT AREA -->
    <div class="admin-content">
        <h2>Administration</h2>
        <p>Select an option from the left panel.</p>
    </div>

</div>

<script>
    function toggleMenu(element) {
        const child = element.nextElementSibling;

        if (child.style.display === "block") {
            child.style.display = "none";
            element.innerHTML = element.innerHTML.replace("▾", "▸");
        } else {
            child.style.display = "block";
            element.innerHTML = element.innerHTML.replace("▸", "▾");
        }
    }
</script>


