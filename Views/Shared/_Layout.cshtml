<!DOCTYPE html>
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Ayushman Solutions</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/sap-login.css" />
</head>

<body class="sap-app-body theme-sap">

    <!-- ===== TOP HEADER ===== -->
    <header class="sap-top-header navbar navbar-dark shadow-sm">
        <div class="container-fluid d-flex justify-content-between align-items-center">

            <!-- LEFT: LOGO + NAME -->
            <div class="d-flex align-items-center">
                @if (HttpContextAccessor.HttpContext?.Session?.GetString("UserName") != null)
                {
                    <button class="navbar-toggler me-2" type="button"
                            data-bs-toggle="offcanvas" data-bs-target="#sapMainMenu"
                            aria-controls="sapMainMenu" aria-label="Toggle menu">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                }
                <img src="~/images/logo.png" width="40" class="me-2" />
                <span class="fw-bold text-white fs-5">Ayushman Solutions</span>
            </div>

            <!-- RIGHT: USER INFO -->
            @if (HttpContextAccessor.HttpContext?.Session?.GetString("UserName") != null)
            {
                <div class="d-flex align-items-center text-white">
                    <span class="me-3">
                        Welcome, @HttpContextAccessor.HttpContext.Session.GetString("UserName")
                    </span>

                    <a class="btn btn-light btn-sm"
                       asp-controller="Account"
                       asp-action="Logout">
                        Logout
                    </a>
                </div>
            }

        </div>
    </header>

    <!-- ===== OFFCANVAS HAMBURGER MENU ===== -->
    @if (HttpContextAccessor.HttpContext?.Session?.GetString("UserName") != null)
    {
        <div class="offcanvas offcanvas-start text-bg-dark" tabindex="-1" id="sapMainMenu" aria-labelledby="sapMainMenuLabel">
            <div class="offcanvas-header">
                <h5 class="offcanvas-title" id="sapMainMenuLabel">Modules</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
            </div>
            <div class="offcanvas-body">
                <div class="list-group">
                    <a class="list-group-item list-group-item-action" asp-controller="Administration" asp-action="Index">Administration</a>
                    <a class="list-group-item list-group-item-action" asp-controller="Sales" asp-action="Index">Sales A/R</a>
                    <a class="list-group-item list-group-item-action" asp-controller="Purchase" asp-action="Index">Purchase</a>
                    <a class="list-group-item list-group-item-action" asp-controller="Inventory" asp-action="Index">Inventory</a>
                    <a class="list-group-item list-group-item-action" asp-controller="BusinessPartner" asp-action="Index">Business Partner</a>
                    <a class="list-group-item list-group-item-action" asp-controller="Banking" asp-action="Index">Banking</a>
                    <a class="list-group-item list-group-item-action" asp-controller="Production" asp-action="Index">Production</a>
                    <a class="list-group-item list-group-item-action" asp-controller="Reports" asp-action="Index">Reports</a>
                </div>
            </div>
        </div>
    }

    @if (HttpContextAccessor.HttpContext?.Session?.GetString("UserName") != null)
    {
        <div class="offcanvas offcanvas-start text-bg-dark" tabindex="-1" id="salesArMenu" aria-labelledby="salesArMenuLabel">
            <div class="offcanvas-header">
                <h5 class="offcanvas-title" id="salesArMenuLabel">Sales A/R</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
            </div>
            <div class="offcanvas-body">
                <div class="list-group">
                    <a class="list-group-item list-group-item-action" asp-controller="Sales" asp-action="BlanketAgreement">Sales Blanket Agreement</a>
                    <a class="list-group-item list-group-item-action" asp-controller="Sales" asp-action="Quotations">Sales Quotation</a>
                    <a class="list-group-item list-group-item-action" asp-controller="Sales" asp-action="Orders">Sales Order</a>
                    <a class="list-group-item list-group-item-action" asp-controller="Sales" asp-action="Delivery">Delivery</a>
                    <a class="list-group-item list-group-item-action" asp-controller="Sales" asp-action="ReturnRequest">Return Request</a>
                    <a class="list-group-item list-group-item-action" asp-controller="Sales" asp-action="Return">Return</a>
                    <a class="list-group-item list-group-item-action" asp-controller="Sales" asp-action="ARDownPaymentRequest">A/R Down Payment Request</a>
                    <a class="list-group-item list-group-item-action" asp-controller="Sales" asp-action="ARDownPaymentInvoice">A/R Down Payment Invoice</a>
                    <a class="list-group-item list-group-item-action" asp-controller="Sales" asp-action="ARInvoices">A/R Invoice</a>
                    <a class="list-group-item list-group-item-action" asp-controller="Sales" asp-action="ARInvoicePayment">A/R Invoice + Payment</a>
                    <a class="list-group-item list-group-item-action" asp-controller="Sales" asp-action="ARCreditMemo">A/R Credit Memo</a>
                    <a class="list-group-item list-group-item-action" asp-controller="Sales" asp-action="DocumentGenerationWizard">Document Generation Wizard</a>
                    <a class="list-group-item list-group-item-action" asp-controller="Sales" asp-action="RecurringTransactions">Recurring Transactions</a>
                </div>
            </div>
        </div>
    }
    <!-- ===== MAIN CONTENT ===== -->
    <main class="sap-app-main container-fluid py-4">
        @RenderBody()
    </main>

    <!-- ===== FOOTER ===== -->
    <footer class="sap-footer text-center py-3">
        © @DateTime.Now.Year Ayushman Solutions |
        SAP Business One Integrated ERP System
    </footer>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>





