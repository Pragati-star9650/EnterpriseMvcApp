@model EnterpriseMvcApp.Models.ErrorViewModel
@{
    ViewData["Title"] = "Error";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="sap-dashboard">
    <div class="sap-dashboard-card">
        <h1 class="sap-dashboard-title" style="color: var(--sap-error);">Error</h1>
        <p class="sap-dashboard-text">An error occurred while processing your request.</p>
        @if (Model?.ShowRequestId == true)
        {
            <p class="sap-dashboard-text"><strong>Request ID:</strong> <code>@Model.RequestId</code></p>
        }
        <p class="sap-dashboard-text" style="margin-top: 1.25rem;"><a asp-controller="Account" asp-action="Login">Return to Login</a></p>
    </div>
</div>
