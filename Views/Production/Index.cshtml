@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Production";
}
<div class="admin-page">
    <div class="admin-sidebar">
        <h5 class="admin-heading">Production</h5>
        <ul class="admin-tree">
            <li>
                <span class="tree-parent" onclick="toggleMenu(this)">▸ Manufacturing</span>
                <ul class="tree-child">
                    <li><a asp-action="BillOfMaterials">BOM (Bill of Materials)</a></li>
                    <li><a asp-action="ProductionOrder">Production Order</a></li>
                    <li><a asp-action="Receipt">Receipt</a></li>
                    <li><a asp-action="Issue">Issue</a></li>
                </ul>
            </li>
        </ul>
    </div>
    <div class="admin-content">
        <h2>Production</h2>
        <p>Select a production function from the left panel.</p>
    </div>
</div>
<script>
    function toggleMenu(element) {
        const child = element.nextElementSibling;
        if (child.style.display === "block") {
            child.style.display = "none";
            element.innerHTML = element.innerHTML.replace("▾", "▸");
        } else {
            child.style.display = "block";
            element.innerHTML = element.innerHTML.replace("▸", "▾");
        }
    }
</script>
