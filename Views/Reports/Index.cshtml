@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Reports";
}
<div class="admin-page">
    <div class="admin-sidebar">
        <h5 class="admin-heading">Reports</h5>
        <ul class="admin-tree">
            <li>
                <span class="tree-parent" onclick="toggleMenu(this)">▸ Sales Reports</span>
                <ul class="tree-child">
                    <li><a href="#">Sales Summary</a></li>
                </ul>
            </li>
            <li>
                <span class="tree-parent" onclick="toggleMenu(this)">▸ Purchase Reports</span>
                <ul class="tree-child">
                    <li><a href="#">Purchase Summary</a></li>
                </ul>
            </li>
        </ul>
    </div>
    <div class="admin-content">
        <h2>Reports</h2>
        <p>Select a report from the left.</p>
    </div>
</div>
<script>
    function toggleMenu(element) {
        const child = element.nextElementSibling;
        if (child.style.display === "block") {
            child.style.display = "none";
            element.innerHTML = element.innerHTML.replace("▾", "▸");
        } else {
            child.style.display = "block";
            element.innerHTML = element.innerHTML.replace("▸", "▾");
        }
    }
</script>
