@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Sales A/R";
}

<div class="admin-page">

    <!-- LEFT TREE MENU -->
    <div class="admin-sidebar">
        <h5 class="admin-heading">Sales A/R</h5>

        <ul class="admin-tree">

            <li>
                <span class="tree-parent" onclick="toggleMenu(this)">
                    ▸ Sales Documents
                </span>
                <ul class="tree-child">
                    <li><a asp-action="Quotations">Sales Quotation</a></li>
                    <li><a asp-action="Orders">Sales Order</a></li>
                    <li><a asp-action="Delivery">Delivery</a></li>
                    <li><a asp-action="ARInvoices">A/R Invoice</a></li>
                    <li><a asp-action="ARCreditMemo">A/R Credit Memo</a></li>
                </ul>
            </li>

            

        </ul>
    </div>

    <!-- RIGHT CONTENT AREA -->
    <div class="admin-content">
        <h2>Sales</h2>
        <p>Select a document type from the left panel.</p>
    </div>

</div>

<script>
    function toggleMenu(element) {
        const child = element.nextElementSibling;

        if (child.style.display === "block") {
            child.style.display = "none";
            element.innerHTML = element.innerHTML.replace("▾", "▸");
        } else {
            child.style.display = "block";
            element.innerHTML = element.innerHTML.replace("▸", "▾");
        }
    }
</script>
